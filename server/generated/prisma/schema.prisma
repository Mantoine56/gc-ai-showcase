// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums matching the GC AI Registry data model
enum PrimaryUsers {
  Employees
  MembersOfPublic
  Both
  Neither
}

enum DevelopedBy {
  Government
  Vendor
  Other
}

enum ProjectStatus {
  InDevelopment
  InProduction
  Retired
}

enum ModerationState {
  Draft
  Submitted
  Approved
  Published
  Archived
}

enum ContactRole {
  Primary
  Technical
  Business
}

// Main Project/AI System model
// Maps to the Excel template from data.xlsx
model Project {
  id String @id @default(cuid())

  // Core Identity
  aiRegisterId       String? @unique // TBS use only, read-only
  nameEN             String // AI system name - English (max 50 chars)
  nameFR             String // AI system name - French (max 50 chars)
  serviceInventoryId String? // Optional alphanumeric ID

  // Organization relationship
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Description and Purpose (Bilingual)
  descriptionEN String // Purpose of AI system - English (max 1000 chars)
  descriptionFR String // Purpose of AI system - French (max 1000 chars)
  primaryUsers  PrimaryUsers // Who uses the AI system

  // Development
  developedBy DevelopedBy
  vendorName  String? // Required if developedBy=Vendor

  // Status and Timeline
  status     ProjectStatus
  statusYear Int? // 4-digit year

  // Capabilities and Features (Bilingual)
  capabilitiesEN String? // Optional - English (max 300 chars)
  capabilitiesFR String? // Optional - French (max 300 chars)

  // Compliance and Governance
  isAutomatedDecisionSystem  Boolean @default(false) // ADS
  openGovAiaId               String? // AIA ID or "Not applicable"
  dataSourcesEN              String? // Free text - English
  dataSourcesFR              String? // Free text - French
  involvesPersonalInfo       Boolean @default(false)
  personalInformationBanksEN String? // Comma/semicolon-separated PIB codes - English
  personalInformationBanksFR String? // Comma/semicolon-separated PIB codes - French
  hasUserNotification        Boolean @default(false)
  atipRequestRefsEN          String? // ATIP request IDs - English (free text)
  atipRequestRefsFR          String? // ATIP request IDs - French (free text)

  // Outcomes and Results (Bilingual)
  outcomesEN String? // Max 500 chars - English
  outcomesFR String? // Max 500 chars - French

  // Internal TBS fields
  source1 String? // Hidden/internal
  source2 String? // Hidden/internal

  // Metadata and Moderation
  moderationState ModerationState @default(Draft)
  featured        Boolean         @default(false) // For featured projects display

  // Open Source
  isOpenSource Boolean @default(false) // Is this an open source project
  githubUrl    String? // GitHub repository URL

  // Audit fields
  createdBy String? // User ID (for future auth)
  updatedBy String? // User ID (for future auth)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  codeRequests CodeRequest[]
  contacts     ProjectContact[]

  @@unique([nameEN, organizationId]) // Prevent duplicates within same org
  // Indexes for search and filtering
  @@index([organizationId])
  @@index([status])
  @@index([isAutomatedDecisionSystem])
  @@index([involvesPersonalInfo])
  @@index([statusYear])
  @@index([moderationState])
  @@index([createdAt])
  @@index([isOpenSource])
}

// Project Contact model
model ProjectContact {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name  String // Contact person's name
  email String // Contact email address
  role  ContactRole // Primary, Technical, or Business contact
  title String? // Job title (optional)
  phone String? // Phone number (optional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([role])
}

// Organization/Department model
model Organization {
  id      String  @id @default(cuid())
  nameEN  String // English name
  nameFR  String // French name
  acronym String? // e.g., "TBS", "CRA"
  url     String? // Department website

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nameEN])
  @@index([acronym])
}

// User model (for future authentication)
model User {
  id          String @id @default(cuid())
  email       String @unique
  displayName String
  roles       String // JSON array stored as string: ["viewer", "submitter", "admin"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
}

// Code access request model
model CodeRequest {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  requesterId    String? // User ID if authenticated
  requesterEmail String // Required even if not authenticated
  message        String // Request message
  status         String  @default("pending") // pending, approved, denied

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

// Audit log for tracking changes
model AuditLog {
  id      String  @id @default(cuid())
  actorId String? // User ID if authenticated
  actor   User?   @relation(fields: [actorId], references: [id])

  action   String // create, update, approve, delete, import, export, etc.
  entity   String // project, organization, user
  entityId String // ID of the affected entity
  diff     String? // JSON string of changes (before/after)

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}
