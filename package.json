{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc --project server/tsconfig.json",
    "build:prisma-scripts": "tsc --project server/prisma/tsconfig.scripts.json",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "tsc --project tsconfig.app.json --noEmit",
    "typecheck:server": "tsc --project server/tsconfig.json --noEmit",
    "test:unit": "tsx --test server/src/dto/project.dto.test.ts server/src/services/project-workflow.service.test.ts server/src/services/audit.service.test.ts",
    "test:e2e": "tsx --test server/src/api-contract.e2e.test.ts",
    "preview": "vite preview",
    "db:generate": "prisma generate --schema=server/prisma/schema.prisma",
    "db:push": "prisma db push --schema=server/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=server/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=server/prisma/schema.prisma",
    "db:seed": "tsx server/prisma/seed.ts",
    "db:seed:excel": "tsx server/prisma/seed-from-excel.ts",
    "db:studio": "prisma studio --schema=server/prisma/schema.prisma",
    "db:sqlite-to-postgres": "tsx server/scripts/sqlite-to-postgres.ts"
  },
  "dependencies": {
